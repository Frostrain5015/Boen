# LLM provider
BOEN_PROVIDER=openai
BOEN_MODEL=astron-code-latest
BOEN_BASE_URL=https://maas-coding-api.cn-huabei-1.xf-yun.com/v2
BOEN_API_KEY=replace-with-api-key

# Service
PORT=8787

# Frost ID browser OAuth config. VITE_* values are bundled into the web build.
VITE_FROST_ID_URL=https://frostrain.tech
VITE_FROST_ID_CLIENT_ID=boen-client

# Frost ID server-side token exchange. Do not expose these with VITE_*.
FROST_ID_INTERNAL_URL=http://127.0.0.1:4000
FROST_ID_CLIENT_ID=boen-client
FROST_ID_CLIENT_SECRET=replace-with-client-secret

# Aliyun OCR for mistake notebook (RecognizeEduPaperStructed)
ALIYUN_ACCESS_KEY_ID=replace-with-access-key-id
ALIYUN_ACCESS_KEY_SECRET=replace-with-access-key-secret
ALIYUN_OCR_ENDPOINT=ocr-api.cn-hangzhou.aliyuncs.com
ALIYUN_OCR_MAX_IMAGE_MB=8
ALIYUN_OCR_NEED_ROTATE=true
ALIYUN_OCR_OUTPUT_ORICOORD=true
